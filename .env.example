# --- Backend ---
APP_ENV=dev
APP_NAME=Bintang
SECRET_KEY=change-me-in-production-32chars-min-please-rotate
ACCESS_TOKEN_EXPIRE_MINUTES=720
DATABASE_URL=sqlite+aiosqlite:///./bintang.db
# For Postgres:
# DATABASE_URL=postgresql+asyncpg://bintang:bintang@db:5432/bintang
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Bintang
